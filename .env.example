# ============================================================
# GLOBALO — Variables d'environnement (production)
# Copier ce fichier en .env et remplir les valeurs.
# Sur cPanel/hébergement : définir via "Environment Variables"
# ou via le .htaccess (SetEnv) ou php-fpm pool.
# ============================================================

# ── Environnement ──────────────────────────────────────────
GLOBALO_ENV=

# ── URL de base (sans slash final) ─────────────────────────
BASE_URL=https://globalo.secogesarl.com/

# ── Base de données ────────────────────────────────────────
DB_HOST=localhost
DB_NAME=cp2640311p29_globalo
DB_USER=cp2640311p29_globalo
DB_PASS=cp2640311p29_globalo

# ── OpenAI (chatbot) ───────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── SEO / Analytics (optionnel) ────────────────────────────
GA_MEASUREMENT_ID=G-XXXXXXXXXX
FB_PIXEL_ID=
LINKEDIN_PARTNER_ID=

# ── Cron Secret (généré aléatoirement) ─────────────────────
# Même valeur que dans Admin → Réseaux Sociaux → Sécurité Cron
# ET dans GitHub Secrets → CRON_SECRET
CRON_SECRET=

# ── InTouch / TouchPay (obligatoire pour les paiements MM) ──
# Ce projet lit les secrets via getenv() : Apache SetEnv (.htaccess),
# variables d’hébergeur (cPanel, etc.), ou pool PHP-FPM.
# Le fichier .env à la racine est chargé automatiquement par app/bootstrap.php (s’il existe).
# Ne jamais committer .env ; copier .env.example → .env sur le serveur.
#
# ── PayTech (https://paytech.sn) ───────────────────────────
# Générer / régénérer les clés dans PayTech → Paramètres → API.
# Après exposition involontaire d’une clé : toujours en créer de nouvelles.
PAYTECH_API_KEY=987eda1da1e05545873edf5be5af0105f8e7c7e00a2a489b981db9d555fb1142
# Si l’éditeur web coupe PAYTECH_API_SECRET sur 2 lignes, la suite sans "=" est reprise automatiquement (bootstrap).
PAYTECH_API_SECRET=85562ca97981239f611c212fde9b91d0ad59f0995cafd8edc0667d7af3b270cc
PAYTECH_ENV=prod

#
# INTOUCH_API_USERNAME=        # auth HTTP Digest (API)
# INTOUCH_API_PASSWORD=
# INTOUCH_LOGIN_AGENT=         # identifiants agent (query URL marchand)
# INTOUCH_PASSWORD_AGENT=
# INTOUCH_ID=                  # ex. code agence TouchPay
# INTOUCH_MERCHANT_URL=        # optionnel (défaut gutouch + placeholders)
# INTOUCH_SERVICE_ORANGE=      # optionnel (défaut ML_PAIEMENTMARCHAND_OM_TP)
# INTOUCH_SERVICE_MOOV=        # optionnel (défaut ML_PAIEMENTMARCHAND_MOOV_TP)
# INTOUCH_SERVICE_WAVE=        # optionnel (défaut ML_PAIEMENTWAVE_TP)
# INTOUCH_CALLBACK_SECRET=     # optionnel : webhook POST /intouch/callback → en-tête X-INTOUCH-SIGNATURE (valeur brute identique au secret)
#
# TouchPay — page de paiement (script JS, doc https://developers.intouchgroup.net/documentation/PAYMENT/22 )
# TOUCHPAY_SECURE_CODE=        # code de sécurité fourni par InTouch pour SendPaymentInfos (lien de redirection)
# TOUCHPAY_SCRIPT_URL=         # optionnel (défaut https://touchpay.gutouch.com/touchpay/script)
# TOUCHPAY_ABONNEMENT_MODE=auto # auto | widget | api — auto : page TouchPay si INTOUCH_ID + TOUCHPAY_SECURE_CODE, sinon formulaire API digest
# TOUCHPAY_SENDPAYMENT_ARGS_JSON=  # optionnel : tableau JSON d’arguments pour SendPaymentInfos (placeholders {{payment_id}}, {{agency_code}}, {{secure_code}}, {{domain_name}}, {{amount}}, {{callback}}, {{return_url}})
