# ══════════════════════════════════════════════════════════════════
#  GLOBALO — public/.htaccess
#  Routage + Sécurité HTTP + Performances
# ══════════════════════════════════════════════════════════════════

# ── 1. Redirections canoniques + HTTPS (production) ───────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1a. Supprimer /public du chemin si le serveur est mal configuré
    RewriteCond %{HTTP_HOST} globalo\.secogesarl\.com [NC]
    RewriteCond %{REQUEST_URI} ^/public/(.*)$ [NC]
    RewriteRule ^public/(.*)$ https://globalo.secogesarl.com/$1 [R=301,L]

    # 1b. Force HTTPS (tout le domaine, pas seulement le sous-domaine principal)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} globalo\.secogesarl\.com [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # 1c. www → non-www (URL canonique unique)
    RewriteCond %{HTTP_HOST} ^www\.globalo\.secogesarl\.com$ [NC]
    RewriteRule ^ https://globalo.secogesarl.com%{REQUEST_URI} [R=301,L]

    # 1d. Trailing slash superflu (sauf racine)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^(.+)/$ /$1 [R=301,L]

    # 1e. Routage principal : tout passe par index.php sauf fichiers/dossiers existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

# ── 2. Sécurité : cacher l'identité du serveur ────────────────────
# Note: ServerTokens et ServerSignature ne peuvent pas être définis dans .htaccess
# (directives serveur uniquement). Elles sont retirées pour éviter les erreurs 500.

# ── 3. Bloquer l'accès aux fichiers sensibles ─────────────────────
<FilesMatch "\.(env|log|sql|bak|sh|htpasswd|git)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquer l'accès direct aux fichiers de config PHP
<FilesMatch "^(bootstrap|config)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# ── 4. En-têtes HTTP de sécurité ──────────────────────────────────
<IfModule mod_headers.c>

    # Clickjacking : la page ne peut être chargée que dans une frame du même domaine
    Header always set X-Frame-Options "SAMEORIGIN"

    # Empêche le MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # XSS protection navigateurs anciens
    Header always set X-XSS-Protection "1; mode=block"

    # Politique de référent
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS : force HTTPS pendant 1 an (activer UNIQUEMENT si HTTPS est stable)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

    # Permissions API browser
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=(self), usb=()"

    # Content Security Policy
    # Header always unset garantit qu'un seul header CSP est envoyé au navigateur,
    # même quand PHP-FPM a déjà positionné le sien (double-header = Chrome applique le plus restrictif).
    Header always unset Content-Security-Policy
    # Sources autorisées par le projet :
    #   scripts  : analytics (GTM/GA), Facebook Pixel, LinkedIn
    #   styles   : Google Fonts + inline (vues PHP)
    #   polices  : Google Fonts gstatic
    #   images   : tout HTTPS (avatars uploads, QR codes externes)
    #   connect  : OpenAI API (chatbot), Google Analytics
    #   forms    : self + paytech.sn (redirect 302 PayTech suivie par Chrome)
    Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' 'unsafe-inline' \
  https://www.googletagmanager.com \
  https://www.google-analytics.com \
  https://connect.facebook.net \
  https://snap.licdn.com \
  https://www.googleadservices.com \
  https://touchpay.gutouch.com \
  https://touchpay.gutouch.net \
  https://paytech.sn; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://paytech.sn; \
font-src 'self' https://fonts.gstatic.com data:; \
img-src 'self' data: blob: https:; \
connect-src 'self' \
  https://api.openai.com \
  https://www.google-analytics.com \
  https://stats.g.doubleclick.net \
  https://www.facebook.com \
  https://api.qrserver.com \
  https://api.gutouch.com \
  https://apidist.gutouch.net \
  https://touchpay.gutouch.com \
  https://touchpay.gutouch.net \
  https://paytech.sn; \
frame-src 'self' https://touchpay.gutouch.com https://touchpay.gutouch.net https://paytech.sn; \
frame-ancestors 'self'; \
form-action 'self' https://pay.wave.com https://touchpay.gutouch.com https://paytech.sn; \
object-src 'none'; \
base-uri 'self';"

    # Supprimer l'en-tête X-Powered-By exposé par PHP
    Header always unset X-Powered-By
    Header unset X-Powered-By

</IfModule>

# ── 5. Limites upload PHP ──────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 8M
    php_value post_max_size 16M
    php_flag expose_php Off
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 8M
    php_value post_max_size 16M
    php_flag expose_php Off
</IfModule>

# ── 6. Compression GZIP (performance) ────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/x-javascript text/javascript
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
    # Ne pas compresser les images déjà compressées
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|ico|gz|zip|bz2)$ no-gzip dont-vary
</IfModule>

# ── 7. Cache navigateur (performance) ─────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Polices et images : cache long
    ExpiresByType image/png            "access plus 6 months"
    ExpiresByType image/jpeg           "access plus 6 months"
    ExpiresByType image/webp           "access plus 6 months"
    ExpiresByType image/gif            "access plus 6 months"
    ExpiresByType image/svg+xml        "access plus 6 months"
    ExpiresByType image/x-icon         "access plus 1 year"
    ExpiresByType font/woff2           "access plus 1 year"
    ExpiresByType font/woff            "access plus 1 year"
    # CSS / JS : cache moyen (versionné avec ?v=timestamp)
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    # HTML / PHP : pas de cache navigateur
    ExpiresByType text/html            "access plus 0 seconds"
    ExpiresDefault                     "access plus 1 week"
</IfModule>

# ── 8. Désactiver le listing de répertoires ───────────────────────
Options -Indexes -MultiViews

# ── 8b. Service Worker + Manifest : JAMAIS mis en cache ───────────
# Obligatoire pour que les utilisateurs qui ont installé l'app
# reçoivent la mise à jour de l'icône automatiquement.
<FilesMatch "^(sw\.js|manifest\.php)$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
        Header always set Service-Worker-Allowed "/"
    </IfModule>
</FilesMatch>

# ── 9. Type MIME correct pour webmanifest ─────────────────────────
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/json          .json
    AddType font/woff2                .woff2
    AddType font/woff                 .woff
    AddType image/webp                .webp
</IfModule>
