# Copier en .env ou définir les variables d'environnement
# DB_HOST=localhost
# DB_NAME=cp2640311p29_globalo
# DB_USER=cp2640311p29_globalo
# DB_PASS=cp2640311p29_globalo
# GLOBALO_ENV=prod

# Wave Mobile Money (semi-automatique Mali)
# WAVE_NUMERO_MARCHAND=+22376000000   # Numéro Wave de la plateforme (marchand)
# WAVE_MARCHAND_ID=GLOBALO            # Identifiant marchand Wave (pour QR code / deep-link)
# WAVE_COMMISSION_PCT=5               # Commission plateforme en % (défaut : 5%)
# WAVE_API_KEY=                       # Clé API Wave (pour intégration automatique future)

# Email (vérification inscription) — optionnel
# Si défini, SMTP est utilisé ; sinon mail() PHP en secours.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@globalo.fr
# Nom d'hôte présenté en EHLO (si le serveur SMTP est strict ; défaut = HTTP_HOST, puis domaine de MAIL_FROM)
# SMTP_EHLO=secogesarl.com
